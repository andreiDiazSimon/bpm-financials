generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["financials", "public"]
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  @@schema("public")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime

  @@schema("public")
}

model gago {
  id   Int     @id @default(autoincrement())
  gago String? @db.VarChar

  @@schema("financials")
}

model Reimbursement {
  id                   String    @id
  expenseReportId      String    @unique
  reimbursementAmount  Float
  paymentMethod        String
  paymentDate          DateTime?
  status               String
  sourceSystem         String    @default("hr2")
  hr2ReimbursementId   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime

  @@schema("financials")
  @@index([status])
}
