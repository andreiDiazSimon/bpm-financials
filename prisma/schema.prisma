generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["financials", "public"]
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  @@schema("public")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime

  @@schema("public")
}

