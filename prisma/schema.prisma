generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core3", "financials", "hr1", "public"]
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  @@schema("public")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime

  @@schema("public")
}

model Client {
  id        Int        @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Contract  Contract[]
  Invoice   Invoice[]

  @@schema("core3")
}

model Contract {
  id                Int            @id @default(autoincrement())
  contractNumber    String         @unique
  title             String
  clientId          Int
  type              ContractType
  status            ContractStatus @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime
  value             Decimal?       @db.Decimal(12, 2)
  paymentTerms      String?
  scopeOfWork       String?
  documentUrl       String?
  terminationClause String?
  renewalTerms      String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  Client            Client         @relation(fields: [clientId], references: [id])

  @@schema("core3")
}

model Equipment {
  id                  Int                   @id @default(autoincrement())
  name                String
  type                EquipmentType
  model               String?
  serialNumber        String?               @unique
  manufacturer        String?
  purchaseDate        DateTime?
  currentHours        Float                 @default(0)
  status              EquipmentStatus       @default(ACTIVE)
  location            String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  MaintenanceLog      MaintenanceLog[]
  MaintenanceSchedule MaintenanceSchedule[]

  @@schema("core3")
}

model Invoice {
  id              Int               @id @default(autoincrement())
  invoiceNumber   String            @unique
  clientId        Int
  projectName     String
  description     String?
  issueDate       DateTime          @default(now())
  dueDate         DateTime
  status          InvoiceStatus     @default(DRAFT)
  subtotal        Decimal           @db.Decimal(10, 2)
  taxRate         Decimal           @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal           @db.Decimal(10, 2)
  totalAmount     Decimal           @db.Decimal(10, 2)
  notes           String?
  sentAt          DateTime?
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Client          Client            @relation(fields: [clientId], references: [id])
  InvoiceLineItem InvoiceLineItem[]
  Payment         Payment[]

  @@schema("core3")
}

model InvoiceLineItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(10, 2)
  Invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@schema("core3")
}

model MaintenanceLog {
  id                  Int                   @id @default(autoincrement())
  equipmentId         Int
  scheduleId          Int?
  title               String
  description         String?
  hoursAtMaintenance  Float
  cost                Decimal?              @db.Decimal(10, 2)
  performedBy         String?
  partsReplaced       String?
  notes               String?
  completedAt         DateTime              @default(now())
  Equipment           Equipment             @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  MaintenanceSchedule MaintenanceSchedule[]

  @@schema("core3")
}

model MaintenanceSchedule {
  id                Int               @id @default(autoincrement())
  equipmentId       Int
  title             String
  description       String?
  intervalHours     Float
  intervalMonths    Int?
  lastMaintenanceId Int?
  nextDueHours      Float
  nextDueDate       DateTime?
  priority          Priority          @default(MEDIUM)
  status            MaintenanceStatus @default(SCHEDULED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  Equipment         Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  MaintenanceLog    MaintenanceLog?   @relation(fields: [lastMaintenanceId], references: [id])

  @@schema("core3")
}

model Payment {
  id            Int           @id @default(autoincrement())
  invoiceId     Int
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  Invoice       Invoice       @relation(fields: [invoiceId], references: [id])

  @@schema("core3")
}

model Permit {
  id                  Int          @id @default(autoincrement())
  permitNumber        String       @unique
  title               String
  type                PermitType
  issuingAuthority    String
  status              PermitStatus @default(VALID)
  issueDate           DateTime
  expirationDate      DateTime
  renewalReminderDays Int          @default(30)
  projectName         String?
  location            String?
  documentUrl         String?
  cost                Decimal?     @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime

  @@schema("core3")
}

model Application {
  id             Int              @id @default(autoincrement())
  jobPostingId   Int
  firstName      String
  lastName       String
  email          String
  phone          String?
  resumeUrl      String?
  coverLetter    String?
  status         String           @default("pending")
  appliedAt      DateTime         @default(now())
  linkedinUrl    String?
  portfolioUrl   String?
  experience     String?
  education      String?
  notes          String?
  JobPosting     JobPosting       @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  OnboardingTask OnboardingTask[]

  @@schema("hr1")
}

model JobPosting {
  id           Int           @id @default(autoincrement())
  title        String
  description  String
  department   String
  location     String
  type         String
  salary       String?
  requirements String
  postedAt     DateTime      @default(now())
  expiresAt    DateTime?
  isActive     Boolean       @default(true)
  Application  Application[]

  @@schema("hr1")
}

model OnboardingTask {
  id            Int         @id @default(autoincrement())
  applicationId Int
  taskType      String
  taskName      String
  isSubmitted   Boolean     @default(false)
  submittedAt   DateTime?
  documentUrl   String?
  notes         String?
  Application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, taskType])
  @@schema("hr1")
}

model Receipt {
  id            Int           @id @default(autoincrement())
  receiptNumber String        @unique
  paymentId     Int           @unique
  clientId      Int
  invoiceId     Int
  amount        Decimal       @db.Decimal(10, 2)
  receiptDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  createdBy     String?

  @@schema("financials")
}

model AccountsReceivable {
  id             Int           @id @default(autoincrement())
  invoiceId      Int           @unique
  clientId       Int
  invoiceNumber  String
  originalAmount Decimal       @db.Decimal(10, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(10, 2)
  balanceDue     Decimal       @db.Decimal(10, 2)
  issueDate      DateTime
  dueDate        DateTime
  status         ARStatus      @default(OUTSTANDING)
  lastPaymentAt  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  AgingBuckets   AgingBucket[]

  @@schema("financials")
}

model AgingBucket {
  id                 Int                @id @default(autoincrement())
  arId               Int
  category           AgingCategory
  amount             Decimal            @db.Decimal(10, 2)
  calculatedAt       DateTime           @default(now())
  AccountsReceivable AccountsReceivable @relation(fields: [arId], references: [id], onDelete: Cascade)

  @@schema("financials")
}

model CollectionActivity {
  id           Int          @id @default(autoincrement())
  clientId     Int
  invoiceId    Int?
  activityType ActivityType
  notes        String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  createdBy    String?

  @@schema("financials")
}

model ClientBalanceSummary {
  id               Int      @id @default(autoincrement())
  clientId         Int      @unique
  clientName       String
  totalInvoiced    Decimal  @db.Decimal(12, 2)
  totalPaid        Decimal  @db.Decimal(12, 2)
  totalOutstanding Decimal  @db.Decimal(12, 2)
  currentBalance   Decimal  @db.Decimal(12, 2)
  overdue30        Decimal  @default(0) @db.Decimal(12, 2)
  overdue60        Decimal  @default(0) @db.Decimal(12, 2)
  overdue90        Decimal  @default(0) @db.Decimal(12, 2)
  lastUpdated      DateTime @updatedAt

  @@schema("financials")
}

model Account {
  id               Int                @id @default(autoincrement())
  code             String             @unique
  name             String
  type             AccountType
  category         AccountCategory
  parentId         Int?
  description      String?
  isActive         Boolean            @default(true)
  openingBalance   Decimal            @default(0) @db.Decimal(12, 2)
  currentBalance   Decimal            @default(0) @db.Decimal(12, 2)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  Parent           Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  Children         Account[]          @relation("AccountHierarchy")
  JournalEntryLine JournalEntryLine[]

  @@schema("financials")
}

model JournalEntry {
  id            Int                @id @default(autoincrement())
  entryNumber   String             @unique
  date          DateTime           @default(now())
  description   String
  referenceType String?
  referenceId   Int?
  totalDebit    Decimal            @db.Decimal(12, 2)
  totalCredit   Decimal            @db.Decimal(12, 2)
  isPosted      Boolean            @default(false)
  postedAt      DateTime?
  postedBy      String?
  createdAt     DateTime           @default(now())
  createdBy     String?
  lines         JournalEntryLine[]

  @@schema("financials")
}

model JournalEntryLine {
  id             Int          @id @default(autoincrement())
  journalEntryId Int
  accountId      Int
  description    String?
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  Account        Account      @relation(fields: [accountId], references: [id])
  JournalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@schema("financials")
}

model GeneralLedgerEntry {
  id             Int      @id @default(autoincrement())
  date           DateTime
  accountId      Int
  accountCode    String
  accountName    String
  description    String
  referenceType  String?
  referenceId    Int?
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  balance        Decimal  @db.Decimal(12, 2)
  journalEntryId Int
  createdAt      DateTime @default(now())

  @@index([accountId, date])
  @@index([referenceType, referenceId])
  @@schema("financials")
}

enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED

  @@schema("core3")
}

enum ContractType {
  SERVICE_AGREEMENT
  RENTAL_AGREEMENT
  PROJECT_CONTRACT
  MAINTENANCE_CONTRACT
  SUPPLY_CONTRACT
  PARTNERSHIP_AGREEMENT
  OTHER

  @@schema("core3")
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
  OUT_OF_SERVICE

  @@schema("core3")
}

enum EquipmentType {
  CRANE
  TRUCK
  EXCAVATOR
  FORKLIFT
  GENERATOR
  COMPRESSOR
  OTHER

  @@schema("core3")
}

enum InvoiceStatus {
  DRAFT
  FINALIZED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED

  @@schema("core3")
}

enum MaintenanceStatus {
  SCHEDULED
  DUE
  OVERDUE
  COMPLETED
  CANCELLED

  @@schema("core3")
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  ONLINE_PAYMENT

  @@schema("core3")
}

enum PermitStatus {
  VALID
  EXPIRED
  SUSPENDED
  REVOKED
  PENDING_RENEWAL

  @@schema("core3")
}

enum PermitType {
  BUSINESS_PERMIT
  BUILDING_PERMIT
  ENVIRONMENTAL_PERMIT
  SAFETY_PERMIT
  TRANSPORT_PERMIT
  WORK_PERMIT
  EQUIPMENT_CERTIFICATION
  OTHER

  @@schema("core3")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("core3")
}

enum ARStatus {
  OUTSTANDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  WRITTEN_OFF

  @@schema("financials")
}

enum AgingCategory {
  CURRENT
  DAYS_1_30
  DAYS_31_60
  DAYS_61_90
  DAYS_90_PLUS

  @@schema("financials")
}

enum ActivityType {
  PAYMENT_RECEIVED
  FOLLOW_UP_CALL
  FOLLOW_UP_EMAIL
  PAYMENT_PLAN_CREATED
  PAYMENT_PLAN_PAYMENT
  DISPUTE_RAISED
  DISPUTE_RESOLVED
  COLLECTION_NOTICE
  LEGAL_ACTION
  WRITE_OFF

  @@schema("financials")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE

  @@schema("financials")
}

enum AccountCategory {
  CURRENT_ASSET
  FIXED_ASSET
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  EQUITY
  REVENUE
  COST_OF_SALES
  OPERATING_EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE

  @@schema("financials")
}
