generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
}
